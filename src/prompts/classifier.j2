{% endif %}

Examples:
- "Help me understand quadratic equations" -> {"intent": "learn", "subject": "Mathematics", "grade": null, "topic": "closest matching topic name from list above"}
- "Give me a question on sequences" -> {"intent": "practice", "subject": "Mathematics", "grade": null, "topic": "closest matching topic name from list above"}
- "Test me on calculus" -> {"intent": "practice", "subject": "Mathematics", "grade": null, "topic": "closest matching topic name from list above"}
- "What tips for paper 1?" -> {"intent": "exam_prep", "subject": "Mathematics", "grade": null, "topic": null}
- "What should I study next?" -> {"intent": "progress", "subject": null, "grade": null, "topic": null}
- "Hi" -> {"intent": "greeting", "subject": null, "grade": null, "topic": null}
- "Who won the PSL?" -> {"intent": "off_topic", "subject": null, "grade": null, "topic": null}
- "a = 5 and d = 3 so T20 = 5 + 19(3) = 62" -> {"intent": "follow_up", "subject": null, "grade": null, "topic": null}